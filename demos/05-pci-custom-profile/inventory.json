{
  "_comment": "Snapshot of a database that backs a payments service. It meets the general baseline but is evaluated here against a stricter payments-scope profile, which uses higher thresholds (16-char passwords, 365-day audit retention).",
  "settings": {
    "network": {
      "require_tls": true,
      "min_tls_version": 1.2,
      "bind_address": "10.40.1.9"
    },
    "auth": {
      "password_min_length": 14,
      "password_complexity_enabled": true,
      "failed_login_lockout_threshold": 5,
      "anonymous_login_enabled": false
    },
    "audit": {
      "logging_enabled": true,
      "retention_days": 90
    },
    "accounts": {
      "default_admin_renamed": true
    },
    "storage": {
      "encryption_at_rest": true
    },
    "diagnostics": {
      "verbose_client_errors": false
    }
  }
}
