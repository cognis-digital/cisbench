{
  "_comment": "Snapshot of a MySQL 8.0 development instance that a security engineer flagged during an internal network sweep. It was stood up quickly for a sprint and never hardened. Settings were captured offline for triage.",
  "settings": {
    "network": {
      "require_tls": false,
      "min_tls_version": 1.0,
      "bind_address": "0.0.0.0"
    },
    "auth": {
      "password_min_length": 8,
      "password_complexity_enabled": false,
      "failed_login_lockout_threshold": 100,
      "anonymous_login_enabled": true
    },
    "audit": {
      "logging_enabled": false,
      "retention_days": 0
    },
    "accounts": {
      "default_admin_renamed": false
    },
    "storage": {
      "encryption_at_rest": false
    },
    "diagnostics": {
      "verbose_client_errors": true
    }
  }
}
