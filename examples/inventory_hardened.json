{
  "_comment": "A fully-hardened example snapshot that passes every check in the built-in baseline.",
  "settings": {
    "network": {
      "require_tls": true,
      "min_tls_version": 1.3,
      "bind_address": "10.0.4.21"
    },
    "auth": {
      "password_min_length": 16,
      "password_complexity_enabled": true,
      "failed_login_lockout_threshold": 5,
      "anonymous_login_enabled": false
    },
    "audit": {
      "logging_enabled": true,
      "retention_days": 365
    },
    "accounts": {
      "default_admin_renamed": true
    },
    "storage": {
      "encryption_at_rest": true
    },
    "diagnostics": {
      "verbose_client_errors": false
    }
  }
}
